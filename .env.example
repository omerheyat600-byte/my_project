# Copy to .env for LOCAL development only.
# On Render, do NOT upload this file — set these same keys in the
# Render dashboard's Environment tab instead.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DB=school_erp

SECRET_KEY=generate-a-long-random-value-here

# Generated by generate_key.py for LICENSE_COMPANY_NAME + this exact expiry date.
# Both must be set together (or leave both blank to use a license.key file instead).
LICENSE_KEY=
LICENSE_EXPIRY=

# Local-only override: browsers reject "Secure" cookies over plain http://,
# so on http://127.0.0.1 testing set this to False. Leave unset (=> True)
# on Render, since Render serves over https.
SESSION_COOKIE_SECURE=False
